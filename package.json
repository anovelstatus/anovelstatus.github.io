{
	"name": "a-novel-status",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"lint": "eslint",
		"lint-fix": "eslint --fix",
		"fmt": "oxfmt . --check",
		"fmt-fix": "oxfmt . --write",
		"website": "cd website && vite",
		"build-website": "cd website && tsc -b && vite build",
		"build-api": "cd api && tsc && node build.ts",
		"config-api": "node config-clasp.ts api",
		"deploy-api": "clasp --project api/dist/.clasp.json push -f && clasp --project api/dist/.clasp.json update-deployment $DEPLOYMENT_ID",
		"build-spreadsheet": "cd spreadsheet && tsc && node build.ts",
		"config-spreadsheet": "node config-clasp.ts spreadsheet",
		"deploy-spreadsheet": "clasp --project spreadsheet/dist/.clasp.json push",
		"test-spreadsheet": "cd spreadsheet && vitest",
		"build-all": "npm run build-api && npm run build-spreadsheet && npm run build-website"
	},
	"devDependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@eslint/js": "^9.39.5",
		"@google/clasp": "^3.3.0",
		"@mui/icons-material": "^9.2.0",
		"@mui/material": "^9.1.2",
		"@tanstack/eslint-plugin-router": "^1.162.0",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-query-devtools": "^5.101.2",
		"@tanstack/react-router": "^1.170.18",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/router-plugin": "^1.168.20",
		"@types/google-apps-script": "2.0.11",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"dotenv": "^17.4.2",
		"es-toolkit": "^1.49.0",
		"eslint": "^9.39.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"material-ui-popup-state": "^5.3.7",
		"oxfmt": "^0.59.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rolldown": "^1.2.0",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
